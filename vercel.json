{
    "version": 2,
    "builds": [
        {
            "src": "/dist/index.cjs",
            "use": "@vercel/node",
            "config": { "includeFiles": ["dist/**"] }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/dist/index.cjs"
        }
    ],
    "buildCommand": "yarn build",
    "installCommand": "yarn install",
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      }
    ]
}
